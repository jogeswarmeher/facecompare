import cv2
import torch
import numpy as np

from facenet_pytorch import MTCNN
from facenet_pytorch import InceptionResnetV1

device='cuda' if torch.cuda.is_available() else 'cpu'

print("Using:",device)

mtcnn = MTCNN(
    image_size=160,
    margin=20,
    device=device
)

model=InceptionResnetV1(
    pretrained='vggface2'
).eval().to(device)

def get_embedding(path):

    img=cv2.imread(path)

    img=cv2.cvtColor(
       img,
       cv2.COLOR_BGR2RGB
    )

    face=mtcnn(img)

    if face is None:
        return None

    face=face.unsqueeze(0).to(device)

    emb=model(face)

    return emb.detach().cpu().numpy()[0]


def cosine(a,b):
    return np.dot(a,b)/(
      np.linalg.norm(a)*
      np.linalg.norm(b)
    )

e1=get_embedding("front.jpg")
e2=get_embedding("side.jpg")

if e1 is None or e2 is None:
    print("Face not detected")
    exit()

score=cosine(e1,e2)

print("Similarity:",score)

if score > 0.7:
    print("Same person")
else:
    print("Different person")

