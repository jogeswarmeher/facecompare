Step 8 — Create comparison script
compare.py
import cv2
import torch
import numpy as np

from facenet_pytorch import (
    MTCNN,
    InceptionResnetV1
)

device='cuda' if torch.cuda.is_available() else 'cpu'

print(device)

#################################
# Face detector
#################################

mtcnn = MTCNN(
    image_size=160,
    margin=20,
    device=device
)

#################################
# Embedding model
#################################

model = InceptionResnetV1(
    pretrained='vggface2'
).eval().to(device)


#################################
# Get embedding
#################################

def get_embedding(path):

    img=cv2.imread(path)

    img=cv2.cvtColor(
        img,
        cv2.COLOR_BGR2RGB
    )

    face=mtcnn(img)

    if face is None:
        return None

    face=face.unsqueeze(0).to(device)

    emb=model(face)

    return emb.detach().cpu().numpy()[0]


#################################
# Cosine similarity
#################################

def cosine(a,b):

    return np.dot(a,b)/(
      np.linalg.norm(a)*
      np.linalg.norm(b)
    )


#################################
# Main
#################################

e1=get_embedding("front.jpg")
e2=get_embedding("side.jpg")

if e1 is None or e2 is None:
    print("Face missing")
    exit()

score=cosine(e1,e2)

print("Similarity:",score)

if score>0.7:
    print("Same person")
else:
    print("Different person")

Run:

python compare.py
What each section does
This:
mtcnn=MTCNN(...)

Detects and aligns face.

This:
model=InceptionResnetV1(...)

Loads pretrained face embedding model.

This:
emb=model(face)

Converts face into 512-number identity vector.

This:
cosine(...)

Compares the two vectors.

Example output
